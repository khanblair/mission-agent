%General Mission Analysis Tool(GMAT) Script
%Template: Deorbit and Lifetime Analysis
%Purpose: Propagate under drag to estimate orbital lifetime; optionally apply
%         a deorbit burn to target reentry altitude.

%---------- Spacecraft
Create Spacecraft SC;
GMAT SC.DateFormat = UTCGregorian;
GMAT SC.Epoch = '01 Jan 2024 00:00:00.000';
GMAT SC.CoordinateSystem = EarthMJ2000Eq;
GMAT SC.DisplayStateType = Keplerian;
GMAT SC.SMA = 6728.0;
GMAT SC.ECC = 0.001;
GMAT SC.INC = 51.6;
GMAT SC.RAAN = 0.0;
GMAT SC.AOP = 0.0;
GMAT SC.TA = 0.0;
GMAT SC.DryMass = 100.0;
GMAT SC.Cd = 2.2;
GMAT SC.Cr = 1.8;
GMAT SC.DragArea = 1.0;
GMAT SC.SRPArea = 1.0;

%---------- Force Model with high-fidelity drag
Create ForceModel FM;
GMAT FM.CentralBody = Earth;
GMAT FM.PrimaryBodies = {Earth};
GMAT FM.PointMasses = {Luna, Sun};
GMAT FM.SRP = On;
GMAT FM.GravityField.Earth.Degree = 10;
GMAT FM.GravityField.Earth.Order = 10;
GMAT FM.Drag.AtmosphereModel = MSISE90;
GMAT FM.Drag.F107 = 150;
GMAT FM.Drag.F107A = 150;
GMAT FM.Drag.MagneticIndex = 3;

Create Propagator Prop;
GMAT Prop.FM = FM;
GMAT Prop.Type = RungeKutta89;
GMAT Prop.InitialStepSize = 60;
GMAT Prop.MinStep = 0.001;
GMAT Prop.MaxStep = 2700;

%---------- Deorbit burn
Create ImpulsiveBurn Deorbit;
GMAT Deorbit.CoordinateSystem = Local;
GMAT Deorbit.Origin = Earth;
GMAT Deorbit.Axes = VNB;
GMAT Deorbit.Element1 = -0.1;
GMAT Deorbit.Element2 = 0.0;
GMAT Deorbit.Element3 = 0.0;

Create ReportFile EphRpt;
GMAT EphRpt.Filename = 'ephemeris.txt';
GMAT EphRpt.Precision = 16;
GMAT EphRpt.Add = {SC.UTCGregorian, SC.EarthMJ2000Eq.X, SC.EarthMJ2000Eq.Y, SC.EarthMJ2000Eq.Z, SC.EarthMJ2000Eq.VX, SC.EarthMJ2000Eq.VY, SC.EarthMJ2000Eq.VZ};
GMAT EphRpt.WriteHeaders = true;
GMAT EphRpt.WriteReport = true;

Create ReportFile AltRpt;
GMAT AltRpt.Filename = 'orbit_elements.txt';
GMAT AltRpt.Add = {SC.UTCGregorian, SC.Earth.Altitude, SC.ECC, SC.INC};
GMAT AltRpt.WriteHeaders = true;
GMAT AltRpt.ColumnWidth = 23;
GMAT AltRpt.WriteReport = true;

%---------- Mission Sequence
BeginMissionSequence;
%  Propagate until altitude < 80 km (reentry) or 25 years, whichever first
Propagate Prop(SC) {SC.Earth.Altitude = 80, SC.ElapsedDays = 9131, OrbitColor = Red};
